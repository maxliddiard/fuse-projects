datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String            @id @default(uuid())
  email            String?           @unique
  password         String?
  emailVerifiedAt  DateTime?
  historySyncDays  Int               @default(90)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  emailAccounts    EmailAccount[]
  whatsAppAccounts WhatsAppAccount[]
}

// AccountStatus: ACTIVE | ERROR | DISCONNECTED
// MailboxRole: INBOX | SENT | DRAFTS | TRASH | SPAM | STARRED | IMPORTANT | ALL_MAIL | CUSTOM
// EmailAddressType: FROM | TO | CC | BCC | REPLY_TO
// EmailMessageStatus: NORMAL | DRAFT | OUTGOING | FAILED

model EmailAccount {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAddress    String
  displayName     String?
  status          String   @default("ACTIVE")
  syncStatus      String   @default("IDLE") // IDLE | SYNCING | FAILED
  syncedMessages  Int      @default(0)
  totalMessages   Int      @default(0)
  accessToken     String
  refreshToken    String?
  tokenExpiresAt  DateTime?
  vendorAccountId        String?
  categorizationPrompt   String?
  lastSyncedAt           DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  mailboxes          Mailbox[]
  conversations      EmailConversation[]
  messages           EmailMessage[]
  discoveredAccounts DiscoveredAccount[]
  pipelineRuns       PipelineRun[]

  @@unique([userId, emailAddress])
}

model Mailbox {
  id          String       @id @default(uuid())
  accountId   String
  account     EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  role        String       @default("CUSTOM")
  name        String
  path        String
  externalId  String?
  totalCount  Int          @default(0)
  unreadCount Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  messages MessageMailbox[]

  @@unique([accountId, path])
}

model EmailConversation {
  id             String       @id @default(uuid())
  accountId      String
  account        EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalThread String
  subject        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  messages EmailMessage[]

  @@unique([accountId, externalThread])
}

model EmailMessage {
  id               String             @id @default(uuid())
  accountId        String
  account          EmailAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversationId   String?
  conversation     EmailConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  externalId       String?
  rfc822MessageId  String?
  subject          String?
  snippet          String?
  fromName         String?
  fromAddress      String?
  replyTo          String?
  date             DateTime?
  hasAttachments   Boolean  @default(false)
  status           String   @default("NORMAL")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  body        MessageBody?
  mailboxes   MessageMailbox[]
  attachments EmailAttachment[]
  addresses   MessageAddress[]
}

model MessageBody {
  id        String       @id @default(uuid())
  messageId String       @unique
  message   EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  text      String?
  html      String?
}

model MessageMailbox {
  id        String       @id @default(uuid())
  messageId String
  message   EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mailboxId String
  mailbox   Mailbox      @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  isSeen    Boolean      @default(false)
  isFlagged Boolean      @default(false)
  isDraft   Boolean      @default(false)

  @@unique([messageId, mailboxId])
}

model EmailAttachment {
  id             String       @id @default(uuid())
  messageId      String
  message        EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename       String?
  mimeType       String?
  size           Int          @default(0)
  contentId      String?
  isInline       Boolean      @default(false)
  providerPartId String?
  createdAt      DateTime     @default(now())
}

model MessageAddress {
  id        String           @id @default(uuid())
  messageId String
  message   EmailMessage     @relation(fields: [messageId], references: [id], onDelete: Cascade)
  type      String
  address   String
  name      String?
}

model DiscoveredAccount {
  id                String   @id @default(uuid())
  emailAccountId    String?
  emailAccount      EmailAccount?    @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  whatsAppAccountId String?
  whatsAppAccount   WhatsAppAccount? @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  sourceType        String           @default("EMAIL") // EMAIL | WHATSAPP | BOTH
  domain            String?
  phoneNumber       String?
  groupJid          String?
  displayName       String?
  emailAddresses    String?          // JSON array of addresses seen
  messageCount      Int              @default(0)
  sentCount         Int              @default(0)
  receivedCount     Int              @default(0)
  isBidirectional   Boolean          @default(false)
  firstSeenAt       DateTime?
  lastSeenAt        DateTime?
  category          String?          // SALES | INVESTOR | SUPPLIER | MANAGEMENT | OTHER
  categoryReason    String?
  salesInsights     String?          // JSON: { contacts, dealStage, recentActivitySummary, keyTopics }
  pipelineRunId     String?
  categorizedAt     DateTime?
  exploredAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([emailAccountId, domain])
  @@unique([whatsAppAccountId, phoneNumber])
  @@unique([whatsAppAccountId, groupJid])
}

model PipelineRun {
  id                  String   @id @default(uuid())
  emailAccountId      String?
  emailAccount        EmailAccount?    @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  whatsAppAccountId   String?
  whatsAppAccount     WhatsAppAccount? @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  sourceType          String           @default("EMAIL") // EMAIL | WHATSAPP
  status              String           @default("RUNNING")   // RUNNING | COMPLETED | FAILED
  stage               String           @default("DISCOVERY") // DISCOVERY | CATEGORIZATION | EXPLORATION | COMPLETED
  accountsFound       Int              @default(0)
  accountsCategorized Int              @default(0)
  autoSkippedCount    Int              @default(0)
  salesExplored       Int              @default(0)
  discoveryMs         Int?
  categorizationMs    Int?
  explorationMs       Int?
  totalMs             Int?
  error               String?
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// WhatsApp Business Cloud API
// WhatsAppAccountStatus: ACTIVE | ERROR | DISCONNECTED
// WhatsAppMessageDirection: INBOUND | OUTBOUND
// WhatsAppMessageType: text | image | document | audio | video | sticker | location | contacts | interactive | button | reaction

model WhatsAppAccount {
  id                     String    @id @default(uuid())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phoneNumber            String
  displayName            String?
  waBusinessAccountId    String?
  phoneNumberId          String?
  accessToken            String?
  categorizationPrompt   String?
  historySyncStatus      String    @default("PENDING") // PENDING | SYNCING | COMPLETED | FAILED
  historySyncedAt         DateTime?
  status                 String    @default("ACTIVE")
  lastSyncedAt           DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  messages           WhatsAppMessage[]
  groups             WhatsAppGroup[]
  discoveredAccounts DiscoveredAccount[]
  pipelineRuns       PipelineRun[]

  @@unique([userId, phoneNumber])
}

model WhatsAppMessage {
  id          String          @id @default(uuid())
  accountId   String
  account     WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  externalId  String?         @unique
  fromPhone   String
  toPhone     String
  fromName    String?
  groupJid    String?
  groupName   String?
  direction   String          // INBOUND | OUTBOUND
  messageType String          @default("text") // text | image | document | audio | video | etc.
  textBody    String?
  caption     String?
  source      String          @default("WEBHOOK") // WEBHOOK | HISTORY_IMPORT
  timestamp   DateTime
  status      String          @default("delivered") // sent | delivered | read | failed
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model WhatsAppGroup {
  id           String          @id @default(uuid())
  accountId    String
  account      WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  jid          String
  name         String?
  participants String?         // JSON array of phone numbers
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([accountId, jid])
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}
